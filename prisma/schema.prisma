generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ---------- Auth (NextAuth) ----------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  households    HouseholdMember[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ---------- Dominio SpendControl ----------
model Household {
  id        String            @id @default(cuid())
  name      String
  currency  String            @default("CLP")
  members   HouseholdMember[]
  finAccounts FinAccount[]
  categories  Category[]
  transactions Transaction[]
  rules       Rule[]
  emailSources EmailSource[]
  createdAt DateTime          @default(now())
}

model HouseholdMember {
  id          String    @id @default(cuid())
  userId      String
  householdId String
  role        String    @default("owner") // owner | editor | viewer
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  @@unique([userId, householdId])
}

model FinAccount {
  id          String        @id @default(cuid())
  householdId String
  name        String
  kind        String        // checking | credit | cash | savings | other
  bank        String?
  last4       String?
  currency    String        @default("CLP")
  openingBalance Int        @default(0) // en centavos/pesos enteros
  archived    Boolean       @default(false)
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt   DateTime      @default(now())
}

model Category {
  id          String        @id @default(cuid())
  householdId String
  name        String
  kind        String        // expense | income | transfer
  color       String        @default("#1E40FF")
  icon        String?
  parentId    String?
  parent      Category?     @relation("Subcat", fields: [parentId], references: [id])
  children    Category[]    @relation("Subcat")
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  @@index([householdId])
}

model Transaction {
  id           String      @id @default(cuid())
  householdId  String
  finAccountId String
  categoryId   String?
  amount       Int         // positivo = ingreso, negativo = gasto (en unidad mínima de la moneda)
  currency     String      @default("CLP")
  description  String
  merchant     String?
  occurredAt   DateTime
  source       String      @default("manual") // manual | email | import
  externalId   String?     // id de mail u origen externo
  status       String      @default("pending") // pending | confirmed | ignored
  rawEmailId   String?
  rawEmail     EmailMessage? @relation(fields: [rawEmailId], references: [id])
  household    Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  finAccount   FinAccount  @relation(fields: [finAccountId], references: [id])
  category     Category?   @relation(fields: [categoryId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  @@index([householdId, occurredAt])
  @@unique([householdId, externalId])
}

model EmailSource {
  id          String   @id @default(cuid())
  householdId String
  provider    String   // gmail
  email       String
  lastSyncAt  DateTime?
  enabled     Boolean  @default(true)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  messages    EmailMessage[]
}

model EmailMessage {
  id           String   @id @default(cuid())
  sourceId     String
  messageId    String   // id del proveedor
  fromAddr     String
  subject      String
  snippet      String
  receivedAt   DateTime
  parsedBank   String?
  parsedAmount Int?
  parsedMerchant String?
  processed    Boolean  @default(false)
  source       EmailSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  @@unique([sourceId, messageId])
}

model Rule {
  id          String   @id @default(cuid())
  householdId String
  matchField  String   // merchant | description | fromAddr
  matchValue  String
  categoryId  String?
  finAccountId String?
  priority    Int      @default(0)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}
